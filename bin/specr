#!/usr/bin/env bash
set -euo pipefail

# NOTE: Heredoc assignments use `IFS= read -r -d '' VAR <<'EOF' || true` instead
# of the more common `VAR="$(cat <<'EOF' ... EOF)"` pattern. This is because
# macOS ships bash 3.2, which has a bug where quotes (e.g. apostrophes in
# "reviewer's") inside heredocs embedded in "$(...)" cause parse errors.

VERSION="0.1.0"
SPEC_DIR=".specr"
INSTALL_DIR="${HOME}/.specr-cli"
STATE_DIRS=("draft" "ready" "in-progress" "completed")

usage() {
  cat <<'EOF'
specr — spec-driven feature development

Usage:
  specr "rough feature idea"         Create a spec interactively (Claude researches, interviews, writes)
  specr list                         List all specs by lifecycle state
  specr ralph [-n N] [spec-file]     Implement a ready spec — automated loop, one task at a time

Options:
  specr --claude "idea"              Use Claude instead of Codex for spec creation
  specr ralph -n 10                  Set max iterations (default: 20)

Other:
  specr auto [-n N] [--model M] "idea"   Autonomous spec creation (two-agent loop, no interaction)
  specr preflight [spec-file]            Readiness check (generic capability test if no spec)
  specr sync [--dry-run]                 AI-verified sync of spec state folders
  specr update                           Update specr to the latest version
  specr --version                        Show version
EOF
}

ensure_state_dirs() {
  for dir in "${STATE_DIRS[@]}"; do
    mkdir -p "${SPEC_DIR}/${dir}"
  done
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || { echo "Error: $1 is not installed or not on PATH." >&2; exit 1; }
}

claude_text_error_reason() {
  local output="${1:-}"
  local normalized
  normalized="$(printf '%s' "$output" | tr '[:upper:]' '[:lower:]')"

  if printf '%s' "$normalized" | grep -Eiq \
    "you're out of extra usage|reached (your )?usage limit|usage limits? apply|wait for (it|your usage limits?) to reset|message limit"; then
    echo "usage limit"
    return 0
  fi

  if printf '%s' "$normalized" | grep -Eiq \
    "invalid_request_error|authentication_error|billing_error|permission_error|not_found_error|request_too_large|rate_limit_error|api_error|overloaded_error|temporarily overloaded|service unavailable|internal server error|network error|fetch failed|econnreset|timed out"; then
    echo "service error"
    return 0
  fi

  return 1
}

# Most recently modified file matching a name glob in a directory. Empty if none.
newest_file() {
  local dir="$1" pattern="$2"
  find "$dir" -maxdepth 1 -name "$pattern" -print0 2>/dev/null \
    | xargs -0 ls -t 2>/dev/null | head -1 || true
}

find_spec_by_prefix() {
  local prefix="$1"
  newest_file "$(dirname "$prefix")" "$(basename "$prefix")-*.md"
}

# Resolve a spec: by name (ready/ then in-progress/) or most recent in ready/.
# Prints path to stdout. Exits on error.
resolve_spec_file() {
  if [[ $# -gt 0 ]]; then
    if [[ "$1" == */* ]]; then
      echo "Error: spec name must not contain path separators." >&2
      exit 1
    fi
    if [[ -f "${SPEC_DIR}/ready/$1" ]]; then
      echo "${SPEC_DIR}/ready/$1"
    elif [[ -f "${SPEC_DIR}/in-progress/$1" ]]; then
      echo "${SPEC_DIR}/in-progress/$1"
    else
      echo "Error: spec '$1' not found in ready/ or in-progress/." >&2
      exit 1
    fi
  else
    local result
    result="$(newest_file "${SPEC_DIR}/ready" '*.md')"
    if [[ -z "$result" ]]; then
      echo "Error: no specs found in ready/. Create one first with 'specr \"idea\"'." >&2
      exit 1
    fi
    echo "$result"
  fi
}

specr_list() {
  ensure_state_dirs

  local found=false
  for dir in "${STATE_DIRS[@]}"; do
    local files=()
    while IFS= read -r -d '' f; do
      files+=("$(basename "$f")")
    done < <(find "${SPEC_DIR}/${dir}" -maxdepth 1 -name '*.md' -print0 2>/dev/null | sort -z)

    if [[ ${#files[@]} -gt 0 ]]; then
      found=true
      echo "${dir}"
      for f in "${files[@]}"; do
        echo "  ${f}"
      done
      echo
    fi
  done

  if [[ "$found" == false ]]; then
    echo "No specs found."
  fi
}

specr_preflight() {
  require_cmd claude
  ensure_state_dirs

  # If a spec argument is given, or a spec exists in ready/, run spec-specific preflight.
  # Otherwise, run a generic capability check.
  local spec_file=""
  if [[ $# -gt 0 ]]; then
    spec_file="$(resolve_spec_file "$@")"
  else
    spec_file="$(newest_file "${SPEC_DIR}/ready" '*.md')"
  fi

  if [[ -n "$spec_file" ]]; then
    local spec_basename
    spec_basename="$(basename "$spec_file")"

    IFS= read -r -d '' PREFLIGHT_PROMPT <<'PREFLIGHT_EOF' || true
Preflight check for a spec to be implemented by Ralph — an automated loop using `claude --print --model sonnet` that implements one top-level task per iteration, commits, and repeats. Non-interactive.

Read-only — do not modify files or implement anything.

Step 1: Verify baseline capabilities (test each, report pass/fail):
- File read (try reading a file)
- File write/edit (check Edit/Write tool access)
- Bash (run a simple command like `ls`)
- Git (run `git status`, check branch, clean working tree)
- WebSearch (check if available)

Step 2: Read the spec only to identify required tools and dependencies (CLIs, env vars, services, packages). Verify each is available.

Step 3: Output a single report:
- **Baseline** — table of capabilities with status (pass/fail)
- **Environment** — git branch, working tree state
- **Spec requirements** — additional tools/dependencies with status (available/missing)
- **Issues** — problems found, with suggested fixes
PREFLIGHT_EOF

    echo "Running preflight check for: ${spec_basename}"
    echo ""

    claude --print --model sonnet \
      --allowedTools "Read Bash Glob Grep WebSearch" \
      --append-system-prompt "${PREFLIGHT_PROMPT}" \
      "Check implementation readiness for the spec: ${spec_file}"
  else
    IFS= read -r -d '' GENERIC_PREFLIGHT_PROMPT <<'GENERIC_PREFLIGHT_EOF' || true
Generic capability check — no spec provided.

Run these checks in order. Clean up everything — leave the working tree exactly as you found it.

Step 1 — File write: Create `tmp_specr_preflight_test.txt` with placeholder content.
Step 2 — File edit: Edit the file to change its content.
Step 3 — File read: Read it back and confirm the edit took effect.
Step 4 — Git stage: `git add tmp_specr_preflight_test.txt`
Step 5 — Git unstage: `git reset tmp_specr_preflight_test.txt`
Step 6 — Cleanup: `rm tmp_specr_preflight_test.txt`
Step 7 — Git status: Confirm the working tree is clean.
Step 8 — Web search: Search for something trivial to confirm WebSearch works.

Output a single report:
- A table with each step, status (pass/fail), and a short note.
- If any step failed, include an **Issues** section with what went wrong and how to fix it.
GENERIC_PREFLIGHT_EOF

    echo "Running generic preflight capability check (no spec provided)"
    echo ""

    claude --print --model sonnet \
      --allowedTools "Read Edit Write Bash Glob Grep WebSearch" \
      --append-system-prompt "${GENERIC_PREFLIGHT_PROMPT}" \
      "Run a generic preflight capability check for specr. Test file creation, editing, reading, git staging/unstaging, cleanup, and web search. Clean up after yourself — leave no trace."
  fi
}

specr_ralph() {
  require_cmd claude
  ensure_state_dirs

  local max_iter=20
  if [[ ${1:-} == "-n" ]]; then
    shift
    if [[ $# -eq 0 || ! "$1" =~ ^[1-9][0-9]*$ ]]; then
      echo "Error: -n requires a positive number." >&2
      exit 1
    fi
    max_iter="$1"
    shift
  fi

  local spec_file
  spec_file="$(resolve_spec_file "$@")"

  # Move from ready/ to in-progress/ if needed
  local spec_basename
  spec_basename="$(basename "$spec_file")"
  local moved_from_ready=false
  if [[ "$spec_file" == "${SPEC_DIR}/ready/"* ]]; then
    mv "$spec_file" "${SPEC_DIR}/in-progress/${spec_basename}"
    moved_from_ready=true
    echo "Moved ${spec_basename} → in-progress/"
  fi
  local SPEC_PATH="${SPEC_DIR}/in-progress/${spec_basename}"

  # If killed before any iteration completes, restore spec to ready/
  if [[ "$moved_from_ready" == true ]]; then
    trap 'mv "${SPEC_PATH}" "${SPEC_DIR}/ready/${spec_basename}" 2>/dev/null; echo ""; echo "Restored ${spec_basename} → ready/ (no work done)"' EXIT
  fi

  # Create feature branch if on main/master
  local current_branch
  current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
  if [[ "$current_branch" == "main" || "$current_branch" == "master" ]]; then
    local short_name
    short_name="$(echo "$spec_basename" | sed 's/^spec-[0-9]*-[0-9]*-//; s/\.md$//')"
    local branch_name="specr/${short_name}"
    echo "On ${current_branch}, creating branch ${branch_name}"
    git checkout -b "$branch_name"
  fi

  IFS= read -r -d '' RALPH_PROMPT <<'RALPH_EOF' || true
You implement exactly one top-level task from a spec, then stop.

Instructions:

1. Read the spec file at the path provided.
2. Find the first unchecked top-level task (`- [ ]`, not indented).
3. Implement that task fully, including all subtasks.
4. Check off each subtask as you complete it (`- [ ]` → `- [x]`), then check off the top-level task.
5. Add a brief implementation note (files changed, approach) indented below the completed top-level task. Do not modify anything else in the spec.
6. Commit on the current branch with a clear message. Do not commit/push to main/master. Do not stage files under .specr/.
7. If ALL top-level tasks are now checked off, output COMPLETED as the very last line.
8. If retrying cannot succeed, continuing risks data corruption, or critical user input is required, output INTERRUPTED as the very last line. Examples: missing external dependency, human decision/credential needed, irreversible data corruption, fundamentally wrong spec assumption.

Constraints:
- Only ONE top-level task per iteration.
- Do not reorder or rewrite the task list.
- Stay focused on implementation — no questions, no waiting for input.
- CRITICAL: Always update the spec before exiting. Unchecked completed work will be repeated.
- Note any problems at the end (permission denials, tool errors, retries) so the next iteration is aware.
- Output a short summary of the progress in the spec in general — how many main tasks are done and how many remain, in total. Keep it short.
RALPH_EOF

  local ITER=0

  # Count top-level task progress (non-indented checkboxes)
  local total_tasks done_tasks
  total_tasks=$(grep -c '^- \[.\]' "$SPEC_PATH" 2>/dev/null) || total_tasks=0
  done_tasks=$(grep -c '^- \[x\]' "$SPEC_PATH" 2>/dev/null) || done_tasks=0

  echo "Starting ralph loop"
  echo "  Spec: ${spec_basename}"
  echo "  Progress: ${done_tasks}/${total_tasks} tasks done · max ${max_iter} iterations"
  echo ""

  while [[ $ITER -lt $max_iter ]]; do
    ITER=$((ITER + 1))

    # Refresh task progress
    total_tasks=$(grep -c '^- \[.\]' "$SPEC_PATH" 2>/dev/null) || total_tasks=0
    done_tasks=$(grep -c '^- \[x\]' "$SPEC_PATH" 2>/dev/null) || done_tasks=0

    echo "━━━ Ralph iteration ${ITER}/${max_iter} · ${done_tasks}/${total_tasks} top-level checkboxes ticked ━━━"

    # After first iteration starts, work may have been done — don't restore to ready/
    trap - EXIT

    local claude_exit=0
    OUTPUT=$(claude --print --model sonnet \
      --allowedTools "Read Edit Write Bash Glob Grep WebSearch" \
      --disallowedTools "Bash(git push *)" \
      --append-system-prompt "${RALPH_PROMPT}" \
      "Implement the next task in the spec: ${SPEC_PATH}") || claude_exit=$?

    if [[ $claude_exit -eq 130 || $claude_exit -eq 137 ]]; then
      echo ""
      echo "━━━ Ralph cancelled by user after ${ITER} iteration(s). Spec remains in-progress. ━━━"
      exit 130
    fi

    if [[ $claude_exit -ne 0 ]]; then
      [[ -n "$OUTPUT" ]] && echo "$OUTPUT"
      [[ -n "$OUTPUT" ]] && echo ""
      echo "━━━ Ralph stopped because Claude exited with status ${claude_exit}. Spec remains in-progress. ━━━"
      exit "$claude_exit"
    fi

    echo "$OUTPUT"
    echo ""

    local claude_error_reason=""
    if claude_error_reason="$(claude_text_error_reason "$OUTPUT")"; then
      echo "━━━ Ralph stopped because Claude reported a ${claude_error_reason}. Spec remains in-progress. ━━━"
      exit 3
    fi

    # Check completion: last non-empty line of output is exactly COMPLETED
    LAST_LINE=$(echo "$OUTPUT" | sed '/^[[:space:]]*$/d' | tail -1)
    if [[ "$LAST_LINE" == "COMPLETED" ]]; then
      echo "━━━ Ralph finished after ${ITER} iteration(s). ━━━"
      mv "${SPEC_PATH}" "${SPEC_DIR}/completed/${spec_basename}"
      echo "Moved ${spec_basename} → completed/"
      exit 0
    fi

    if [[ "$LAST_LINE" == "INTERRUPTED" ]]; then
      echo ""
      echo "━━━ Ralph INTERRUPTED after ${ITER} iteration(s). Review output above for details. ━━━"
      exit 2
    fi
  done

  echo "━━━ Ralph hit max iterations (${max_iter}). Spec remains in-progress. ━━━"
  exit 1
}

specr_auto() {
  require_cmd claude

  local max_rounds=5
  local model="sonnet"

  # Parse flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n)
        shift
        if [[ $# -eq 0 || ! "$1" =~ ^[1-9][0-9]*$ ]]; then
          echo "Error: -n requires a positive number." >&2
          exit 1
        fi
        max_rounds="$1"
        shift
        ;;
      --model)
        shift
        if [[ $# -eq 0 ]]; then
          echo "Error: --model requires a model argument." >&2
          exit 1
        fi
        model="$1"
        shift
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ $# -eq 0 ]]; then
    echo "Error: a rough feature idea is required." >&2
    echo "Usage: specr auto [-n N] [--model MODEL] \"rough feature idea\"" >&2
    exit 1
  fi

  local rough_idea="$*"
  local STAMP
  STAMP="$(date +%Y%m%d-%H%M%S)"
  local SPEC_PATH_PREFIX="${SPEC_DIR}/draft/spec-${STAMP}"

  ensure_state_dirs

  IFS= read -r -d '' AUTO_SPECCER_PROMPT <<'SPECCER_EOF' || true
You write and refine specs in an autonomous two-agent loop. A reviewer evaluates between rounds. Be direct and task-focused. No banter.

Responsibilities:
- First invocation: research the codebase, create a spec file named exactly: __SPEC_PATH_PREFIX__-<short-descriptive-name>.md (short, lowercase, hyphenated suffix).
- Subsequent invocations: read the existing spec, incorporate reviewer feedback, update in place.

Resolve ambiguities yourself via codebase research. Only flag questions that genuinely require human input. The reviewer is a second opinion, not a replacement for your own investigation.

If the input is broad, pick a concrete, well-scoped focus. A focused spec beats a sprawling one.

Spec state folders under __SPEC_DIR__/:
  draft/ → ready/ → in-progress/ → completed/
Always create and update under draft/. Do NOT move the file — the bash loop handles transitions.

Spec requirements — must be implementable and include:
- What we are solving
- Technical implementation (largest section by far)
- Relevant findings about the current project
- Constraints and assumptions
- Acceptance criteria
- Task list with subtasks

The spec must be self-contained — implementable without prior context.

Task list requirements:
- Use `- [ ]` Markdown checklists for progress tracking.
- Complete: all tasks done = feature fully implemented.
- Concrete and implementation-oriented.
- Reflect dependencies and ordering where relevant.
- Optimized for agent-driven implementation: group subtasks under top-level tasks, each an independently committable unit. Scale task count to scope.
- Tests and docs belong as subtasks under related implementation, not standalone top-level tasks.
- Do not artificially limit spec size. Tasks are executed one at a time by an automated process with no degradation from list length — a 50-task spec runs as reliably as a 5-task spec. Correctness, completeness, and well-structured grouping matter; brevity for its own sake does not.

Think aloud as you work.
SPECCER_EOF
  AUTO_SPECCER_PROMPT="${AUTO_SPECCER_PROMPT//__SPEC_PATH_PREFIX__/$SPEC_PATH_PREFIX}"
  AUTO_SPECCER_PROMPT="${AUTO_SPECCER_PROMPT//__SPEC_DIR__/$SPEC_DIR}"

  IFS= read -r -d '' AUTO_REVIEWER_PROMPT <<'REVIEWER_EOF' || true
You are a reviewer and researcher in an autonomous spec creation loop. Strictly read-only — never edit, create, or move files.

Dual role:
1. Researcher: answer open questions by investigating the codebase. Cite file paths and line numbers. Focus on facts.
2. Quality gate: decide whether the spec is complete and ready.

Each round:
1. Read the speccer's output (provided in user prompt).
2. Read the spec file at the provided path. If none exists, tell the speccer to create one.
3. Research the codebase to answer open questions and verify technical claims.
4. Evaluate completeness:
   - All required sections present (What we are solving, Technical implementation, Relevant findings, Constraints/assumptions, Acceptance criteria, Task list)
   - Technical implementation is concrete, accurate, and implementable
   - Task list is complete with `- [ ]` checkboxes, well-scoped top-level tasks with subtasks
   - Spec is self-contained
5. Evaluate on its own terms — complete for the scope it chose? Do not expand scope.

Decision:
- Complete and meets all requirements → output COMPLETED as the very last line.
- Needs work → provide research findings and concrete feedback. Do NOT output COMPLETED.
REVIEWER_EOF

  local MAX_ROUNDS=$max_rounds
  local ROUND=1
  local SPECCER_OUTPUT=""
  local SPEC_PATH=""

  echo "Starting autonomous spec for: \"${rough_idea}\""
  echo "Spec file prefix: ${SPEC_PATH_PREFIX}-<name>.md"
  echo ""

  # Round 1: Initial spec creation
  echo "━━━ Round ${ROUND}/${MAX_ROUNDS}: Creating initial spec ━━━"
  local claude_exit=0
  SPECCER_OUTPUT=$(claude --print --model "$model" \
    --allowedTools "Read Edit Write Bash Glob Grep WebSearch" \
    --disallowedTools "Bash(git push *)" \
    --append-system-prompt "${AUTO_SPECCER_PROMPT}" \
    "Rough feature idea: ${rough_idea}

Research the codebase and create the spec file at: ${SPEC_PATH_PREFIX}-<short-descriptive-name>.md") || claude_exit=$?

  if [[ $claude_exit -eq 130 || $claude_exit -eq 137 ]]; then
    echo ""
    echo "━━━ Auto spec cancelled by user. Spec remains in draft (if created). ━━━"
    exit 130
  fi

  echo "$SPECCER_OUTPUT"
  echo ""

  while [[ $ROUND -lt $MAX_ROUNDS ]]; do
    ROUND=$((ROUND + 1))

    # Discover spec file via glob
    SPEC_PATH="$(find_spec_by_prefix "$SPEC_PATH_PREFIX")"

    # Review phase
    echo "━━━ Round ${ROUND}/${MAX_ROUNDS}: Reviewing ━━━"
    local reviewer_exit=0
    local REVIEWER_OUTPUT
    local spec_context
    if [[ -n "$SPEC_PATH" ]]; then
      spec_context="Spec file path: ${SPEC_PATH}"
    else
      spec_context="No spec file found yet at prefix: ${SPEC_PATH_PREFIX}-*.md"
    fi

    REVIEWER_OUTPUT=$(claude --print --model "$model" \
      --allowedTools "Read Glob Grep WebSearch" \
      --append-system-prompt "${AUTO_REVIEWER_PROMPT}" \
      "Speccer output this round:
${SPECCER_OUTPUT}

${spec_context}

Review the spec and provide feedback, or output COMPLETED if the spec is ready.") || reviewer_exit=$?

    if [[ $reviewer_exit -eq 130 || $reviewer_exit -eq 137 ]]; then
      echo ""
      echo "━━━ Auto spec cancelled by user. Spec remains in draft (if created). ━━━"
      exit 130
    fi

    echo "$REVIEWER_OUTPUT"
    echo ""

    # Check for COMPLETED
    local LAST_LINE
    LAST_LINE=$(echo "$REVIEWER_OUTPUT" | sed '/^[[:space:]]*$/d' | tail -1)
    if [[ "$LAST_LINE" == "COMPLETED" ]]; then
      # Rediscover spec path in case it was just created
      SPEC_PATH="$(find_spec_by_prefix "$SPEC_PATH_PREFIX")"
      if [[ -n "$SPEC_PATH" ]]; then
        local spec_basename
        spec_basename="$(basename "$SPEC_PATH")"
        mv "$SPEC_PATH" "${SPEC_DIR}/ready/${spec_basename}"
        echo "━━━ Spec complete after ${ROUND} round(s) ━━━"
        echo "Moved ${spec_basename} → ready/"
      else
        echo "━━━ Spec complete after ${ROUND} round(s) ━━━"
        echo "Warning: could not find spec file to move to ready/."
      fi
      exit 0
    fi

    # Check if we've hit max rounds before refining
    if [[ $ROUND -ge $MAX_ROUNDS ]]; then
      break
    fi

    # Refine phase (same round — reviewer gave feedback, speccer incorporates it)
    echo "━━━ Round ${ROUND}/${MAX_ROUNDS}: Refining spec ━━━"
    local refine_exit=0
    # Rediscover spec path
    SPEC_PATH="$(find_spec_by_prefix "$SPEC_PATH_PREFIX")"
    local spec_path_msg
    if [[ -n "$SPEC_PATH" ]]; then
      spec_path_msg="Current spec file: ${SPEC_PATH}"
    else
      spec_path_msg="No spec file found yet. Create it at: ${SPEC_PATH_PREFIX}-<short-descriptive-name>.md"
    fi

    SPECCER_OUTPUT=$(claude --print --model "$model" \
      --allowedTools "Read Edit Write Bash Glob Grep WebSearch" \
      --disallowedTools "Bash(git push *)" \
      --append-system-prompt "${AUTO_SPECCER_PROMPT}" \
      "${spec_path_msg}

Reviewer feedback:
${REVIEWER_OUTPUT}

Read the current spec file (if it exists), incorporate the feedback above, and update the spec.") || refine_exit=$?

    if [[ $refine_exit -eq 130 || $refine_exit -eq 137 ]]; then
      echo ""
      echo "━━━ Auto spec cancelled by user. Spec remains in draft (if created). ━━━"
      exit 130
    fi

    echo "$SPECCER_OUTPUT"
    echo ""
  done

  echo "━━━ Hit max rounds (${MAX_ROUNDS}). Spec remains in draft/. ━━━"
  exit 1
}

specr_sync() {
  require_cmd claude

  ensure_state_dirs

  local dry_run=false
  if [[ ${1:-} == "--dry-run" ]]; then
    dry_run=true
  fi

  IFS= read -r -d '' SYNC_PROMPT <<'SYNC_EOF' || true
You audit spec state folders against the actual codebase.

Instructions:

1. Discover all .md spec files under .specr/: draft/, ready/, in-progress/, completed/, and root (legacy orphans).
2. For each spec:
   a. Read the task list (`- [ ]` and `- [x]` lines).
   b. Check the codebase for described files, functions, configs, or behaviors.
   c. Determine correct state:
      - draft — incomplete or not actionable
      - ready — complete spec, no implementation started
      - in-progress — partially implemented
      - completed — fully implemented
3. Report: current folder, recommended folder, one-line reason.
4. Move misplaced files (using mv) — unless the user prompt says dry run, then only report.

Output format — simple list, one per entry:

- spec-name.md: ready → completed (all tasks implemented)
- other-spec.md: draft (no change)

If files were moved, end with "Moved N spec(s)".
SYNC_EOF

  local user_prompt
  if [[ "$dry_run" == true ]]; then
    user_prompt="Sync the spec files in .specr/ to their correct state folders. This is a dry run — report recommendations only, do NOT move any files."
    echo "Running sync (dry run)..."
  else
    user_prompt="Sync the spec files in .specr/ to their correct state folders. Move any files that are in the wrong state folder."
    echo "Running sync..."
  fi
  echo ""

  claude --print --model sonnet \
    --allowedTools "Read Edit Write Bash Glob Grep WebSearch" \
    --disallowedTools "Bash(git push *)" \
    --append-system-prompt "${SYNC_PROMPT}" \
    "${user_prompt}"
}

specr_create() {
  local use_claude=false
  if [[ ${1:-} == "--claude" ]]; then
    use_claude=true
    shift
  fi

  local spec_tool="codex"
  if [[ "$use_claude" == true ]]; then
    spec_tool="claude"
  elif ! command -v codex >/dev/null 2>&1; then
    echo "codex not found, falling back to claude"
    spec_tool="claude"
  fi

  require_cmd "$spec_tool"

  local ROUGH_IDEA="$*"
  local STAMP
  STAMP="$(date +%Y%m%d-%H%M%S)"
  local SPEC_PATH_PREFIX="${SPEC_DIR}/draft/spec-${STAMP}"

  ensure_state_dirs

  IFS= read -r -d '' SYSTEM_PROMPT <<'CREATE_EOF' || true
You are in Specr mode — specification only. Turn the user's rough feature idea into an implementable spec. Do not implement anything or edit project files (only the spec file). Exceptions are fine if the user explicitly asks.

Be direct and concise — keep things moving.

Two writing modes:
- Chat with user: friendly, energetic.
- Spec document: concise, professional, neutral, structured.

Spec state folders under __SPEC_DIR__/:
  draft/ → ready/ → in-progress/ → completed/
States can be skipped when appropriate. Move specs between folders using mv.

Spec output file lives under __SPEC_DIR__/draft/.
Timestamped prefix: __SPEC_PATH_PREFIX__
Once you can name the feature, create the file once as:
  __SPEC_PATH_PREFIX__-<short-descriptive-name>.md
Keep the suffix short, lowercase, hyphenated. Use that path for the rest of the session.

You were started from within the target project directory.

Workflow

Research the codebase (and web if needed) first, so you ask informed questions.

Then have a real conversation. The most important thing is understanding what the user wants and why. Have at least one discussion round to confirm intent — help them think through uncertainties, surface things they might not have considered. Then dig into constraints, preferences, and trade-offs. Challenge assumptions, explore what-ifs. Create the spec file once conclusions solidify.

Do deeper research as needed to verify assumptions with high confidence (package source, web search for current API behavior).

Spec requirements — must be implementable and include:
- What we are solving
- Technical implementation (largest section by far)
- Relevant findings about the current project
- Constraints and assumptions
- Acceptance criteria
- Task list with subtasks

The spec must be self-contained — understandable without prior context from this conversation.

Task list requirements:
- Use `- [ ]` Markdown checklists for progress tracking.
- Complete: all tasks done = feature fully implemented.
- Concrete and implementation-oriented.
- Reflect dependencies and ordering where relevant.
- Optimized for agent-driven implementation: group subtasks under top-level tasks, each an independently committable unit. Scale task count to scope.
- Tests and docs belong as subtasks under related implementation, not standalone top-level tasks.
- Do not artificially limit spec size. Tasks are executed one at a time by an automated process with no degradation from list length — a 50-task spec runs as reliably as a 5-task spec. Correctness, completeness, and well-structured grouping matter; brevity for its own sake does not.

Consider end-user impact, not just technical implementation. Bring in product/UX considerations when appropriate. For purely backend/infrastructure work, stay grounded in technical context.

Be cautious about treating inferred details as final decisions. Verify through research or ask the user. Include sources for important conclusions when useful.

Guiding toward ready

Resolve all open questions before moving to ready — research first, ask the user only when research can't answer. Once the spec is complete (all sections filled, task list solid, acceptance criteria clear), move it to ready/ yourself. Do not ask permission. Then tell the user:
- The spec is ready.
- How to implement: "Run `specr ralph` to start implementation."
- Only for small specs (1–2 main tasks): mention they can run `claude "implement the spec at <path>"` directly. For 3+ tasks, recommend `specr ralph` only.

Mention the spec state (folder and path) after creating it, after state changes, and when asked.
CREATE_EOF
  SYSTEM_PROMPT="${SYSTEM_PROMPT//__SPEC_DIR__/$SPEC_DIR}"
  SYSTEM_PROMPT="${SYSTEM_PROMPT//__SPEC_PATH_PREFIX__/$SPEC_PATH_PREFIX}"
  USER_PROMPT="Rough feature idea:
${ROUGH_IDEA}

Start Specr mode now."

  echo "Starting Specr in $(pwd) (using ${spec_tool})"
  echo "Spec file prefix: ${SPEC_PATH_PREFIX}-<short-descriptive-name>.md"

  if [[ "$use_claude" == true ]]; then
    exec claude --append-system-prompt "${SYSTEM_PROMPT}" "${USER_PROMPT}"
  else
    exec codex -c "developer_instructions=$(printf '%s' "${SYSTEM_PROMPT}")" --search "${USER_PROMPT}"
  fi
}

specr_update() {
  if [[ ! -d "$INSTALL_DIR/.git" ]]; then
    echo "Error: specr install directory not found at ${INSTALL_DIR}" >&2
    echo "If you installed specr elsewhere, cd there and run: git pull" >&2
    exit 1
  fi
  echo "Updating specr..."
  git -C "$INSTALL_DIR" pull --ff-only
  echo "Updated to $(git -C "$INSTALL_DIR" log -1 --format='%h %s')"
}

# Argument routing
if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "$1" in
  auto)
    shift
    specr_auto "$@"
    ;;
  list)
    specr_list
    ;;
  preflight)
    shift
    specr_preflight "$@"
    ;;
  sync)
    shift
    specr_sync "$@"
    ;;
  ralph)
    shift
    specr_ralph "$@"
    ;;
  update)
    specr_update
    ;;
  -v|--version)
    echo "specr ${VERSION}"
    exit 0
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  --claude)
    specr_create "$@"
    ;;
  *)
    specr_create "$@"
    ;;
esac
