#!/usr/bin/env bash
set -euo pipefail

SPEC_DIR=".specr"
STATE_DIRS=("draft" "ready" "in-progress" "completed")

usage() {
  cat <<'EOF'
Usage:
  specr [--claude] "rough feature idea"  Start a new spec session (default: codex, --claude to use claude)
  specr ralph [-n N] [spec-file]         Implement a ready spec via ralph loop (default 20 iterations)
  specr preflight [spec-file]            Run a readiness check before implementing a spec
  specr sync [--dry-run]                 AI-verified sync of spec state folders
  specr list                             List all specs by state
EOF
}

ensure_state_dirs() {
  for dir in "${STATE_DIRS[@]}"; do
    mkdir -p "${SPEC_DIR}/${dir}"
  done
}

specr_list() {
  ensure_state_dirs

  local found=false
  for dir in "${STATE_DIRS[@]}"; do
    local files=()
    while IFS= read -r -d '' f; do
      files+=("$(basename "$f")")
    done < <(find "${SPEC_DIR}/${dir}" -maxdepth 1 -name '*.md' -print0 2>/dev/null | sort -z)

    if [[ ${#files[@]} -gt 0 ]]; then
      found=true
      echo "${dir}"
      for f in "${files[@]}"; do
        echo "  ${f}"
      done
      echo
    fi
  done

  if [[ "$found" == false ]]; then
    echo "No specs found."
  fi
}

specr_preflight() {
  if ! command -v claude >/dev/null 2>&1; then
    echo "Error: claude is not installed or not on PATH." >&2
    exit 1
  fi

  ensure_state_dirs

  local spec_file=""

  if [[ $# -gt 0 ]]; then
    local basename="$1"
    if [[ -f "${SPEC_DIR}/ready/${basename}" ]]; then
      spec_file="${SPEC_DIR}/ready/${basename}"
    elif [[ -f "${SPEC_DIR}/in-progress/${basename}" ]]; then
      spec_file="${SPEC_DIR}/in-progress/${basename}"
    else
      echo "Error: spec '${basename}' not found in ready/ or in-progress/." >&2
      exit 1
    fi
  else
    spec_file="$(find "${SPEC_DIR}/ready" -maxdepth 1 -name '*.md' -print0 2>/dev/null \
      | xargs -0 ls -t 2>/dev/null | head -1)"
    if [[ -z "$spec_file" ]]; then
      echo "Error: no specs found in ready/. Create one first with 'specr \"idea\"'." >&2
      exit 1
    fi
  fi

  local spec_basename
  spec_basename="$(basename "$spec_file")"
  local SPEC_PATH="$spec_file"

  PREFLIGHT_PROMPT="$(cat <<'PREFLIGHT_EOF'
Preflight check for a spec that will be implemented by Ralph — an automated loop using `claude --print --model sonnet` that implements one top-level task per iteration, commits, and repeats. Non-interactive, no user input possible.

Do NOT implement anything. Do NOT modify any files. Read-only analysis only.

Step 1: Verify baseline capabilities. Actually test each one and report pass/fail:
- File read (try reading a file)
- File write/edit (check Edit/Write tool access)
- Bash (run a simple command like `ls`)
- Git (run `git status`, check branch, clean working tree)
- WebSearch (check if available for API doc lookups)

Step 2: Read the spec and explore the relevant codebase (key files, project structure, dependencies). Analyze tasks for additional requirements beyond baseline — e.g., specific CLIs (npm, cargo, docker), environment variables, running services, external dependencies. Verify each one you find.

Step 3: Output a single report:
- **Baseline** — table of baseline capabilities with status (pass/fail)
- **Environment** — git branch, working tree state, project build state
- **Spec-specific** — any additional requirements found in step 2, with status
- **Issues** — problems found, with suggested fixes
PREFLIGHT_EOF
)"

  echo "Running preflight check for: ${spec_basename}"
  echo ""

  claude --print --model sonnet --append-system-prompt "${PREFLIGHT_PROMPT}" \
    "Check implementation readiness for the spec: ${SPEC_PATH}"
}

specr_ralph() {
  if ! command -v claude >/dev/null 2>&1; then
    echo "Error: claude is not installed or not on PATH." >&2
    exit 1
  fi

  ensure_state_dirs

  local max_iter=20
  # Parse -n flag for iteration count
  if [[ ${1:-} == "-n" ]]; then
    shift
    if [[ $# -eq 0 || ! "$1" =~ ^[0-9]+$ ]]; then
      echo "Error: -n requires a numeric argument." >&2
      exit 1
    fi
    max_iter="$1"
    shift
  fi

  local spec_file=""

  if [[ $# -gt 0 ]]; then
    # Argument provided: look in ready/ first, then in-progress/
    local basename="$1"
    if [[ -f "${SPEC_DIR}/ready/${basename}" ]]; then
      spec_file="${SPEC_DIR}/ready/${basename}"
    elif [[ -f "${SPEC_DIR}/in-progress/${basename}" ]]; then
      spec_file="${SPEC_DIR}/in-progress/${basename}"
    else
      echo "Error: spec '${basename}' not found in ready/ or in-progress/." >&2
      exit 1
    fi
  else
    # No argument: pick most recently modified .md from ready/
    spec_file="$(find "${SPEC_DIR}/ready" -maxdepth 1 -name '*.md' -print0 2>/dev/null \
      | xargs -0 ls -t 2>/dev/null | head -1)"
    if [[ -z "$spec_file" ]]; then
      echo "Error: no specs found in ready/. Create one first with 'specr \"idea\"'." >&2
      exit 1
    fi
  fi

  # Move from ready/ to in-progress/ if needed
  local spec_basename
  spec_basename="$(basename "$spec_file")"
  if [[ "$spec_file" == "${SPEC_DIR}/ready/"* ]]; then
    mv "$spec_file" "${SPEC_DIR}/in-progress/${spec_basename}"
    echo "Moved ${spec_basename} → in-progress/"
  fi
  local SPEC_PATH="${SPEC_DIR}/in-progress/${spec_basename}"

  # Create feature branch if on main/master
  local current_branch
  current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
  if [[ "$current_branch" == "main" || "$current_branch" == "master" ]]; then
    local short_name
    short_name="$(echo "$spec_basename" | sed 's/^spec-[0-9]*-[0-9]*-//; s/\.md$//')"
    local branch_name="specr/${short_name}"
    echo "On ${current_branch}, creating branch ${branch_name}"
    git checkout -b "$branch_name"
  fi

  RALPH_PROMPT="$(cat <<'RALPH_EOF'
You are operating in Ralph mode — an automated implementation loop.

Your job is to implement exactly one top-level task from a spec file, then stop.

Instructions:

1. Read the spec file at the path provided in the user prompt.
2. Find the first unchecked top-level task (a line matching `- [ ]` that is not indented under another task).
3. Implement that task fully, including all of its subtasks.
4. After completing each subtask, check it off in the spec file (`- [ ]` → `- [x]`).
5. After completing the top-level task, check it off too.
6. Add a brief implementation note directly below the completed top-level task in the spec file — a short summary of what was done (files changed, approach taken). Indent it under the task. Do not modify anything else in the spec.
7. Commit all changes (code + spec file update) on the current branch. Do NOT commit or push to main/master. Write a clear commit message describing what was implemented.
8. After committing, check whether ALL top-level tasks in the spec are now checked off (`- [x]`). If yes, output the single word COMPLETED as the very last thing in your response. If not, just end normally.
9. If you encounter a situation where **retrying cannot succeed**, **continuing risks data corruption**, or **critical user input is required before you can proceed**, output the single word INTERRUPTED as the very last thing in your response. Do not attempt to continue or retry. Examples of when to use INTERRUPTED:
   - A required external dependency or service is missing and cannot be installed within the task.
   - A task requires a decision or credential that only a human can provide.
   - Continuing would overwrite or corrupt data in a way that cannot be undone.
   - A fundamental assumption in the spec is incorrect and the task cannot be implemented as written.

Constraints:
- Implement only ONE top-level task (including its subtasks).
- Do not reorder, restructure, or rewrite the task list.
- Do not modify the spec beyond checking off tasks and adding implementation notes.
- Stay focused on implementation. Do not ask questions or wait for input.
- CRITICAL: Before exiting, you MUST update the spec file to reflect any progress made during this iteration. Every subtask or task you completed must be checked off, and an implementation note must be added. The spec file is the sole source of truth for progress across iterations — if you do not update it, your work will be repeated or lost. The only exception is if you made zero progress (e.g., the very first action failed).
RALPH_EOF
)"

  local MAX_ITER=$max_iter
  local ITER=0

  echo "Starting ralph loop for: ${spec_basename} (max ${MAX_ITER} iterations)"
  echo ""

  while [[ $ITER -lt $MAX_ITER ]]; do
    ITER=$((ITER + 1))
    echo "━━━ Ralph iteration ${ITER}/${MAX_ITER} ━━━"

    local claude_exit=0
    OUTPUT=$(claude --print --model sonnet --append-system-prompt "${RALPH_PROMPT}" \
      "Implement the next task in the spec: ${SPEC_PATH}") || claude_exit=$?

    if [[ $claude_exit -eq 130 || $claude_exit -eq 137 ]]; then
      echo ""
      echo "━━━ Ralph cancelled by user after ${ITER} iteration(s). Spec remains in-progress. ━━━"
      exit 130
    fi

    echo "$OUTPUT"
    echo ""

    # Check completion: last non-empty line of output is exactly COMPLETED
    LAST_LINE=$(echo "$OUTPUT" | sed '/^[[:space:]]*$/d' | tail -1)
    if [[ "$LAST_LINE" == "COMPLETED" ]]; then
      echo "━━━ Ralph finished after ${ITER} iteration(s). ━━━"
      mv "${SPEC_PATH}" "${SPEC_DIR}/completed/${spec_basename}"
      echo "Moved ${spec_basename} → completed/"
      exit 0
    fi

    if [[ "$LAST_LINE" == "INTERRUPTED" ]]; then
      echo ""
      echo "━━━ Ralph INTERRUPTED after ${ITER} iteration(s). Review output above for details. ━━━"
      exit 2
    fi
  done

  echo "━━━ Ralph hit max iterations (${MAX_ITER}). Spec remains in-progress. ━━━"
  exit 1
}

specr_sync() {
  if ! command -v claude >/dev/null 2>&1; then
    echo "Error: claude is not installed or not on PATH." >&2
    exit 1
  fi

  ensure_state_dirs

  local dry_run=false
  if [[ ${1:-} == "--dry-run" ]]; then
    dry_run=true
  fi

  SYNC_PROMPT="$(cat <<'SYNC_EOF'
You are a spec state auditor. Your job is to analyze spec files and determine whether each one is in the correct state folder based on the actual codebase.

Instructions:

1. Discover all .md spec files across these folders under .specr/: draft/, ready/, in-progress/, completed/, and the .specr/ root (legacy orphans).
2. For each spec file found:
   a. Read the spec content, especially the task list (lines matching `- [ ]` and `- [x]`).
   b. Explore the codebase to verify whether the described changes actually exist — check for the files, functions, configs, or behaviors the spec describes.
   c. Determine the correct state:
      - draft — spec is incomplete, missing sections, or not yet actionable.
      - ready — spec is complete and well-formed, but no implementation work has started in the codebase.
      - in-progress — some but not all described work exists in the codebase.
      - completed — all described work is fully implemented in the codebase.
3. For each spec, report: current folder, recommended folder, and a one-line reason.
4. Move files that need to change (using mv) to their correct state folder — unless the user prompt indicates this is a dry run, in which case only report what would change without moving anything.

Output format — use a simple list, one spec per entry. Do NOT use tables. Example:

- spec-name.md: ready → completed (all tasks implemented)
- other-spec.md: draft (no change)

If any files were moved, end with a short "Moved N spec(s)" summary line.
SYNC_EOF
)"

  local user_prompt
  if [[ "$dry_run" == true ]]; then
    user_prompt="Sync the spec files in .specr/ to their correct state folders. This is a dry run — report recommendations only, do NOT move any files."
    echo "Running sync (dry run)..."
  else
    user_prompt="Sync the spec files in .specr/ to their correct state folders. Move any files that are in the wrong state folder."
    echo "Running sync..."
  fi
  echo ""

  claude --print --model sonnet --append-system-prompt "${SYNC_PROMPT}" \
    "${user_prompt}"
}

specr_create() {
  local use_claude=false
  if [[ ${1:-} == "--claude" ]]; then
    use_claude=true
    shift
  fi

  local spec_tool="codex"
  if [[ "$use_claude" == true ]]; then
    spec_tool="claude"
  fi

  if ! command -v "$spec_tool" >/dev/null 2>&1; then
    echo "Error: ${spec_tool} is not installed or not on PATH." >&2
    exit 1
  fi

  ROUGH_IDEA="$*"
  STAMP="$(date +%Y%m%d-%H%M%S)"
  SPEC_PATH_PREFIX="${SPEC_DIR}/draft/spec-${STAMP}"

  ensure_state_dirs

  SYSTEM_PROMPT="$(cat <<EOF
You are operating in a specialized workflow called Specr mode.

In Specr mode, your role is specification only. Your job is to help the user turn a rough feature idea into an implementable specification for this project. The goal is to make the speccing process feel simple, clear, collaborative, lightweight, and even fun.

Speccing can easily become tedious, so use a bit of a friendly banter and humor to lighten it up.

Use two distinct writing modes:
- Chat with the user: friendly, with a bit of banter.
- Spec document: concise, professional, neutral, and structured.

Do not let the chat sound like a design document, and do not let the spec sound like banter.

Your responsibilities and constraints in this mode:
- Help the user create and refine a specification.
- Do not implement the feature.
- In general, do not edit application code, tests, configs, migrations, or any project files other than the spec output file for this session. If you are explicitly instructed by the user to make an exception to this rule, thats fine.  
- Do not switch into planning or execution mode.

Spec state folders

Specs live in state folders under ${SPEC_DIR}/:

  draft/        — spec is being written or refined (initial state)
  ready/        — spec is finalized and ready for implementation
  in-progress/  — spec is currently being implemented
  completed/    — implementation is done

The normal flow is draft → ready → in-progress → completed, but states can be skipped when appropriate.

You are responsible for moving spec files between state folders during the session. To move a spec, use a shell command (e.g. mv) to relocate it from one folder to another, keeping the filename unchanged. Always confirm with the user before changing the state of a spec.

The spec output file for this session must live under: ${SPEC_DIR}/draft/
Use this timestamped filename prefix for the session: ${SPEC_PATH_PREFIX}
Once you understand the feature well enough to name it clearly, create the spec file exactly once using this format:

${SPEC_PATH_PREFIX}-<short-descriptive-name>.md

Keep the suffix short, specific, lowercase, and hyphenated.
After creating the file, use that same path for the rest of the session. Do not rename it later.

You were started from within the target project directory.

Workflow

Initially, after first message from user:
- Do lightweight preliminary research to understand the issue.
- Once you understand the feature well enough to name it clearly, create the spec file using the exact format above.

Then for the rest of the conversaion:
- Have an engaging discussion with the user.
- Ask clarifying questions to flesh out the feature and improve the spec.
- As conclusions begin to solidify, you are encouraged to do deeper research in the codebase and, when useful, consult external sources to verify or disprove assumptions with high confidence. For example, read relevant package source code or use web search to confirm current API behavior mentioned in the spec.

Spec requirements

The spec must be implementable and include:
- What we are solving
- Technical implementation (this should be the largest section by far)
- Relevant findings about the current project
- Constraints and assumptions
- Acceptance criteria
- Task list with subtasks

The spec must be self-contained and written so that someone implementing it later can understand it without needing prior context from this conversation.

Task list requirements

The task list must:
- Use Markdown checklists in the form - [ ] so implementation progress can be tracked later.
- Be complete: if all tasks and subtasks are finished, the feature should be fully implemented.
- Be concrete and implementation-oriented, not just high-level themes.
- Reflect dependencies and ordering where that matters.
- Be optimized for agent-driven implementation: use around 4–10 top-level tasks, each grouping related subtasks. Avoid splitting into many tiny standalone tasks or collapsing everything into 1–2 massive tasks. Each top-level task should represent a meaningful, independently committable unit of work. Scale the number of tasks to the spec — a small feature may only need 2–3, a large one may need up to 10.

While developing the spec, consider how the feature affects end users, not just the technical implementation. When appropriate, think slightly beyond the most obvious implementation path and bring in useful product or UX considerations. If the work is primarily backend or infrastructure and broader user impact is not relevant, stay grounded in the technical context.

Be cautious about treating inferred details as final decisions. When something is uncertain, verify it through research or ask the user.

When useful, include sources for important conclusions. It is valuable both to confirm an assumption and to disprove one — and to report either outcome clearly.

Status updates

Mention the current spec state (folder and file path) after creating it, after state changes, and when the user asks.

When the spec moves to ready/, suggest how to implement it with a short and simple sentence:
- Most specs: specr ralph (picks up the latest ready spec automatically).
- Small and simple specs: run claude with a prompt like: implement the spec <full path to spec>.
EOF
)"
  USER_PROMPT="$(cat <<EOF
Rough feature idea:
${ROUGH_IDEA}

Start Specr mode now.
EOF
)"

  echo "Starting Specr in $(pwd) (using ${spec_tool})"
  echo "Spec file prefix: ${SPEC_PATH_PREFIX}-<short-descriptive-name>.md"

  if [[ "$use_claude" == true ]]; then
    exec claude --append-system-prompt "${SYSTEM_PROMPT}" "${USER_PROMPT}"
  else
    exec codex -c "developer_instructions=$(printf '%s' "${SYSTEM_PROMPT}")" --search "${USER_PROMPT}"
  fi
}

# Argument routing
if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "$1" in
  list)
    specr_list
    ;;
  preflight)
    shift
    specr_preflight "$@"
    ;;
  sync)
    shift
    specr_sync "$@"
    ;;
  ralph)
    shift
    specr_ralph "$@"
    ;;
  --claude)
    specr_create "$@"
    ;;
  *)
    specr_create "$@"
    ;;
esac
