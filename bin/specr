#!/usr/bin/env bash
set -euo pipefail

# NOTE: Heredoc assignments use `IFS= read -r -d '' VAR <<'EOF' || true` instead
# of the more common `VAR="$(cat <<'EOF' ... EOF)"` pattern. This is because
# macOS ships bash 3.2, which has a bug where quotes (e.g. apostrophes in
# "reviewer's") inside heredocs embedded in "$(...)" cause parse errors.

VERSION="0.1.0"
SPEC_DIR=".specr"
INSTALL_DIR="${HOME}/.specr-cli"
STATE_DIRS=("draft" "ready" "in-progress" "completed")

usage() {
  cat <<'EOF'
specr — spec-driven feature development

Usage:
  specr "rough feature idea"         Create a spec interactively (Claude researches, interviews, writes)
  specr list                         List all specs by lifecycle state
  specr ralph [-n N] [spec-file]     Implement a ready spec — automated loop, one task at a time

Options:
  specr --claude "idea"              Use Claude instead of Codex for spec creation
  specr ralph -n 10                  Set max iterations (default: 20)

Other:
  specr auto [-n N] [--model M] "idea"   Autonomous spec creation (two-agent loop, no interaction)
  specr preflight [spec-file]            Readiness check (generic capability test if no spec)
  specr sync [--dry-run]                 AI-verified sync of spec state folders
  specr update                           Update specr to the latest version
  specr --version                        Show version
EOF
}

ensure_state_dirs() {
  for dir in "${STATE_DIRS[@]}"; do
    mkdir -p "${SPEC_DIR}/${dir}"
  done
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || { echo "Error: $1 is not installed or not on PATH." >&2; exit 1; }
}

claude_text_error_reason() {
  local output="${1:-}"
  local normalized
  normalized="$(printf '%s' "$output" | tr '[:upper:]' '[:lower:]')"

  if printf '%s' "$normalized" | grep -Eiq \
    "you're out of extra usage|reached (your )?usage limit|usage limits? apply|wait for (it|your usage limits?) to reset|message limit"; then
    echo "usage limit"
    return 0
  fi

  if printf '%s' "$normalized" | grep -Eiq \
    "invalid_request_error|authentication_error|billing_error|permission_error|not_found_error|request_too_large|rate_limit_error|api_error|overloaded_error|temporarily overloaded|service unavailable|internal server error|network error|fetch failed|econnreset|timed out"; then
    echo "service error"
    return 0
  fi

  return 1
}

# Most recently modified file matching a name glob in a directory. Empty if none.
newest_file() {
  local dir="$1" pattern="$2"
  find "$dir" -maxdepth 1 -name "$pattern" -print0 2>/dev/null \
    | xargs -0 ls -t 2>/dev/null | head -1 || true
}

find_spec_by_prefix() {
  local prefix="$1"
  newest_file "$(dirname "$prefix")" "$(basename "$prefix")-*.md"
}

# Resolve a spec: by name (ready/ then in-progress/) or most recent in ready/.
# Prints path to stdout. Exits on error.
resolve_spec_file() {
  if [[ $# -gt 0 ]]; then
    if [[ "$1" == */* ]]; then
      echo "Error: spec name must not contain path separators." >&2
      exit 1
    fi
    if [[ -f "${SPEC_DIR}/ready/$1" ]]; then
      echo "${SPEC_DIR}/ready/$1"
    elif [[ -f "${SPEC_DIR}/in-progress/$1" ]]; then
      echo "${SPEC_DIR}/in-progress/$1"
    else
      echo "Error: spec '$1' not found in ready/ or in-progress/." >&2
      exit 1
    fi
  else
    local result
    result="$(newest_file "${SPEC_DIR}/ready" '*.md')"
    if [[ -z "$result" ]]; then
      echo "Error: no specs found in ready/. Create one first with 'specr \"idea\"'." >&2
      exit 1
    fi
    echo "$result"
  fi
}

specr_list() {
  ensure_state_dirs

  local found=false
  for dir in "${STATE_DIRS[@]}"; do
    local files=()
    while IFS= read -r -d '' f; do
      files+=("$(basename "$f")")
    done < <(find "${SPEC_DIR}/${dir}" -maxdepth 1 -name '*.md' -print0 2>/dev/null | sort -z)

    if [[ ${#files[@]} -gt 0 ]]; then
      found=true
      echo "${dir}"
      for f in "${files[@]}"; do
        echo "  ${f}"
      done
      echo
    fi
  done

  if [[ "$found" == false ]]; then
    echo "No specs found."
  fi
}

specr_preflight() {
  require_cmd claude
  ensure_state_dirs

  # If a spec argument is given, or a spec exists in ready/, run spec-specific preflight.
  # Otherwise, run a generic capability check.
  local spec_file=""
  if [[ $# -gt 0 ]]; then
    spec_file="$(resolve_spec_file "$@")"
  else
    spec_file="$(newest_file "${SPEC_DIR}/ready" '*.md')"
  fi

  if [[ -n "$spec_file" ]]; then
    local spec_basename
    spec_basename="$(basename "$spec_file")"

    IFS= read -r -d '' PREFLIGHT_PROMPT <<'PREFLIGHT_EOF' || true
Preflight permission check for a spec that will be implemented by Ralph — an automated loop using `claude --print --model sonnet` that implements one top-level task per iteration, commits, and repeats. Non-interactive, no user input possible.

Do NOT implement anything. Do NOT modify any files. Do NOT review or critique the spec content. Your only job is to verify that the tools and permissions needed to implement this spec are available.

Step 1: Verify baseline capabilities. Actually test each one and report pass/fail:
- File read (try reading a file)
- File write/edit (check Edit/Write tool access)
- Bash (run a simple command like `ls`)
- Git (run `git status`, check branch, clean working tree)
- WebSearch (check if available for API doc lookups)

Step 2: Read the spec only to identify what tools and dependencies the implementation would require — e.g., specific CLIs (npm, cargo, docker), environment variables, running services, external packages. Do NOT summarize or evaluate the spec itself. Just extract the requirements and verify each one is available.

Step 3: Output a single report:
- **Baseline** — table of baseline capabilities with status (pass/fail)
- **Environment** — git branch, working tree state
- **Spec requirements** — any additional tools or dependencies the spec needs, with status (available/missing)
- **Issues** — problems found, with suggested fixes
PREFLIGHT_EOF

    echo "Running preflight check for: ${spec_basename}"
    echo ""

    claude --print --model sonnet \
      --allowedTools "Read Bash Glob Grep WebSearch" \
      --append-system-prompt "${PREFLIGHT_PROMPT}" \
      "Check implementation readiness for the spec: ${spec_file}"
  else
    IFS= read -r -d '' GENERIC_PREFLIGHT_PROMPT <<'GENERIC_PREFLIGHT_EOF' || true
Generic preflight capability check for specr. No spec was provided, so you are testing that all the tools and permissions needed for a typical spec implementation are working.

Run the following checks in order. Each check must pass before moving on. Clean up everything you create — leave the working tree exactly as you found it.

Step 1 — File write: Create a file called `tmp_specr_preflight_test.txt` with some placeholder content.
Step 2 — File edit: Edit that file to change its content.
Step 3 — File read: Read the file back and confirm the edit took effect.
Step 4 — Git stage: Run `git add tmp_specr_preflight_test.txt` to stage it.
Step 5 — Git unstage: Run `git reset tmp_specr_preflight_test.txt` to unstage it.
Step 6 — Cleanup: Delete the file with `rm tmp_specr_preflight_test.txt`.
Step 7 — Git status: Run `git status` to confirm the working tree is clean (same as before).
Step 8 — Web search: Do a web search for something trivial (e.g., "hello world") to confirm WebSearch works.

Output a single report:
- A table with each step, its status (pass/fail), and a short note.
- If any step failed, include a **Issues** section with what went wrong and how to fix it.
GENERIC_PREFLIGHT_EOF

    echo "Running generic preflight capability check (no spec provided)"
    echo ""

    claude --print --model sonnet \
      --allowedTools "Read Edit Write Bash Glob Grep WebSearch" \
      --append-system-prompt "${GENERIC_PREFLIGHT_PROMPT}" \
      "Run a generic preflight capability check for specr. Test file creation, editing, reading, git staging/unstaging, cleanup, and web search. Clean up after yourself — leave no trace."
  fi
}

specr_ralph() {
  require_cmd claude
  ensure_state_dirs

  local max_iter=20
  if [[ ${1:-} == "-n" ]]; then
    shift
    if [[ $# -eq 0 || ! "$1" =~ ^[1-9][0-9]*$ ]]; then
      echo "Error: -n requires a positive number." >&2
      exit 1
    fi
    max_iter="$1"
    shift
  fi

  local spec_file
  spec_file="$(resolve_spec_file "$@")"

  # Move from ready/ to in-progress/ if needed
  local spec_basename
  spec_basename="$(basename "$spec_file")"
  local moved_from_ready=false
  if [[ "$spec_file" == "${SPEC_DIR}/ready/"* ]]; then
    mv "$spec_file" "${SPEC_DIR}/in-progress/${spec_basename}"
    moved_from_ready=true
    echo "Moved ${spec_basename} → in-progress/"
  fi
  local SPEC_PATH="${SPEC_DIR}/in-progress/${spec_basename}"

  # If killed before any iteration completes, restore spec to ready/
  if [[ "$moved_from_ready" == true ]]; then
    trap 'mv "${SPEC_PATH}" "${SPEC_DIR}/ready/${spec_basename}" 2>/dev/null; echo ""; echo "Restored ${spec_basename} → ready/ (no work done)"' EXIT
  fi

  # Create feature branch if on main/master
  local current_branch
  current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
  if [[ "$current_branch" == "main" || "$current_branch" == "master" ]]; then
    local short_name
    short_name="$(echo "$spec_basename" | sed 's/^spec-[0-9]*-[0-9]*-//; s/\.md$//')"
    local branch_name="specr/${short_name}"
    echo "On ${current_branch}, creating branch ${branch_name}"
    git checkout -b "$branch_name"
  fi

  IFS= read -r -d '' RALPH_PROMPT <<'RALPH_EOF' || true
You are operating in Ralph mode — an automated implementation loop.

Your job is to implement exactly one top-level task from a spec file, then stop.

Instructions:

1. Read the spec file at the path provided in the user prompt.
2. Find the first unchecked top-level task (a line matching `- [ ]` that is not indented under another task).
3. Implement that task fully, including all of its subtasks.
4. After completing each subtask, check it off in the spec file (`- [ ]` → `- [x]`).
5. After completing the top-level task, check it off too.
6. Add a brief implementation note directly below the completed top-level task in the spec file — a short summary of what was done (files changed, approach taken). Indent it under the task. Do not modify anything else in the spec.
7. Commit your code changes on the current branch. Do not commit or push to main/master. Write a clear commit message describing what was implemented. Do not stage or commit files under the .specr/ directory — leave them as untracked/unstaged. The user manages these separately, typically via .gitignore.
8. After committing, check whether ALL top-level tasks in the spec are now checked off (`- [x]`). If yes, output the single word COMPLETED as the very last thing in your response. If not, just end normally.
9. If you encounter a situation where **retrying cannot succeed**, **continuing risks data corruption**, or **critical user input is required before you can proceed**, output the single word INTERRUPTED as the very last thing in your response. Do not attempt to continue or retry. Examples of when to use INTERRUPTED:
   - A required external dependency or service is missing and cannot be installed within the task.
   - A task requires a decision or credential that only a human can provide.
   - Continuing would overwrite or corrupt data in a way that cannot be undone.
   - A fundamental assumption in the spec is incorrect and the task cannot be implemented as written.

Constraints:
- Implement only ONE top-level task (including its subtasks).
- Do not reorder, restructure, or rewrite the task list.
- Do not modify the spec beyond checking off tasks and adding implementation notes.
- Stay focused on implementation. Do not ask questions or wait for input.
- CRITICAL: Before exiting, you MUST update the spec file to reflect any progress made during this iteration. Every subtask or task you completed must be checked off, and an implementation note must be added. The spec file is the sole source of truth for progress across iterations — if you do not update it, your work will be repeated or lost. The only exception is if you made zero progress (e.g., the very first action failed).
- At the end of your response, briefly note any problems you encountered — permission denials, tool errors, retries, or anything that cost significant time or tokens — so the next iteration (or a human reviewer) is aware.
RALPH_EOF

  local ITER=0

  echo "Starting ralph loop for: ${spec_basename} (max ${max_iter} iterations)"
  echo ""

  while [[ $ITER -lt $max_iter ]]; do
    ITER=$((ITER + 1))
    echo "━━━ Ralph iteration ${ITER}/${max_iter} ━━━"

    # After first iteration starts, work may have been done — don't restore to ready/
    trap - EXIT

    local claude_exit=0
    OUTPUT=$(claude --print --model sonnet \
      --allowedTools "Read Edit Write Bash Glob Grep WebSearch" \
      --disallowedTools "Bash(git push *)" \
      --append-system-prompt "${RALPH_PROMPT}" \
      "Implement the next task in the spec: ${SPEC_PATH}") || claude_exit=$?

    if [[ $claude_exit -eq 130 || $claude_exit -eq 137 ]]; then
      echo ""
      echo "━━━ Ralph cancelled by user after ${ITER} iteration(s). Spec remains in-progress. ━━━"
      exit 130
    fi

    if [[ $claude_exit -ne 0 ]]; then
      [[ -n "$OUTPUT" ]] && echo "$OUTPUT"
      [[ -n "$OUTPUT" ]] && echo ""
      echo "━━━ Ralph stopped because Claude exited with status ${claude_exit}. Spec remains in-progress. ━━━"
      exit "$claude_exit"
    fi

    echo "$OUTPUT"
    echo ""

    local claude_error_reason=""
    if claude_error_reason="$(claude_text_error_reason "$OUTPUT")"; then
      echo "━━━ Ralph stopped because Claude reported a ${claude_error_reason}. Spec remains in-progress. ━━━"
      exit 3
    fi

    # Check completion: last non-empty line of output is exactly COMPLETED
    LAST_LINE=$(echo "$OUTPUT" | sed '/^[[:space:]]*$/d' | tail -1)
    if [[ "$LAST_LINE" == "COMPLETED" ]]; then
      echo "━━━ Ralph finished after ${ITER} iteration(s). ━━━"
      mv "${SPEC_PATH}" "${SPEC_DIR}/completed/${spec_basename}"
      echo "Moved ${spec_basename} → completed/"
      exit 0
    fi

    if [[ "$LAST_LINE" == "INTERRUPTED" ]]; then
      echo ""
      echo "━━━ Ralph INTERRUPTED after ${ITER} iteration(s). Review output above for details. ━━━"
      exit 2
    fi
  done

  echo "━━━ Ralph hit max iterations (${max_iter}). Spec remains in-progress. ━━━"
  exit 1
}

specr_auto() {
  require_cmd claude

  local max_rounds=5
  local model="sonnet"

  # Parse flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n)
        shift
        if [[ $# -eq 0 || ! "$1" =~ ^[1-9][0-9]*$ ]]; then
          echo "Error: -n requires a positive number." >&2
          exit 1
        fi
        max_rounds="$1"
        shift
        ;;
      --model)
        shift
        if [[ $# -eq 0 ]]; then
          echo "Error: --model requires a model argument." >&2
          exit 1
        fi
        model="$1"
        shift
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ $# -eq 0 ]]; then
    echo "Error: a rough feature idea is required." >&2
    echo "Usage: specr auto [-n N] [--model MODEL] \"rough feature idea\"" >&2
    exit 1
  fi

  local rough_idea="$*"
  local STAMP
  STAMP="$(date +%Y%m%d-%H%M%S)"
  local SPEC_PATH_PREFIX="${SPEC_DIR}/draft/spec-${STAMP}"

  ensure_state_dirs

  IFS= read -r -d '' AUTO_SPECCER_PROMPT <<'SPECCER_EOF' || true
You are one of two agents in an autonomous spec creation loop. You write and refine the spec; a reviewer agent evaluates it between rounds.

Be direct and task-focused. No banter.

Your responsibilities:
- On the first invocation: research the codebase, then create a spec file. Name it exactly: __SPEC_PATH_PREFIX__-<short-descriptive-name>.md (keep the suffix short, lowercase, hyphenated). Write the full spec to this file.
- On subsequent invocations: read the existing spec file at the path provided, incorporate the reviewer's feedback, and update the spec in place.

Make reasonable decisions when possible. Only flag genuine ambiguities — things that codebase research cannot resolve and that meaningfully affect the implementation. Default to moving forward.

Do thorough codebase research yourself. The reviewer is a second opinion, not a replacement for your own investigation.

If the input is broad or vague, pick a concrete, well-scoped focus area and commit to it. A focused, implementable spec is better than a sprawling one.

Spec state folders

Specs live in state folders under __SPEC_DIR__/:

  draft/        — spec is being written or refined (initial state)
  ready/        — spec is finalized and ready for implementation
  in-progress/  — spec is currently being implemented
  completed/    — implementation is done

Always create and update the spec under draft/. Do NOT move the file — the bash loop handles state transitions.

Spec requirements

The spec must be implementable and include:
- What we are solving
- Technical implementation (this should be the largest section by far)
- Relevant findings about the current project
- Constraints and assumptions
- Acceptance criteria
- Task list with subtasks

The spec must be self-contained and written so that someone implementing it later can understand it without needing prior context.

Task list requirements

The task list must:
- Use Markdown checklists in the form - [ ] so implementation progress can be tracked later.
- Be complete: if all tasks and subtasks are finished, the feature should be fully implemented.
- Be concrete and implementation-oriented, not just high-level themes.
- Reflect dependencies and ordering where that matters.
- Be optimized for agent-driven implementation: group related subtasks under meaningful top-level tasks, where each top-level task represents an independently committable unit of work. There is no single right answer for task count — it depends entirely on the scope. A small feature might have 3 top-level tasks, a large one might have 20 or 30 or more. Those numbers are only examples, not targets. The only rule is that the list must be "ralph-able": correct, complete, and well-organized into logical top-level groups with clear subtasks.

Output free-form text as you work — describe your reasoning, note open questions or uncertainties, state when you believe the spec is complete. Write naturally.
SPECCER_EOF
  AUTO_SPECCER_PROMPT="${AUTO_SPECCER_PROMPT//__SPEC_PATH_PREFIX__/$SPEC_PATH_PREFIX}"
  AUTO_SPECCER_PROMPT="${AUTO_SPECCER_PROMPT//__SPEC_DIR__/$SPEC_DIR}"

  IFS= read -r -d '' AUTO_REVIEWER_PROMPT <<'REVIEWER_EOF' || true
You are a reviewer and researcher in an autonomous spec creation loop. You are strictly read-only — never edit, create, or move any files.

Your dual role:
1. Researcher: answer open questions from the speccer's output by investigating the codebase. Cite file paths and line numbers. Focus on facts.
2. Quality gate: decide whether the spec is complete and ready for implementation.

Steps each round:
1. Read the speccer's output from this round (provided in the user prompt).
2. Read the spec file at the path provided (if available). If no spec file exists yet, tell the speccer it must create one.
3. Research the codebase to answer any open questions or verify technical claims in the spec.
4. Evaluate the spec for completeness:
   - All required sections present: What we are solving, Technical implementation, Relevant findings, Constraints and assumptions, Acceptance criteria, Task list
   - Technical implementation is concrete, accurate, and implementable
   - Task list is complete, uses - [ ] checkboxes, has 4–10 top-level tasks with subtasks
   - Spec is self-contained (no context needed from this conversation)
5. Evaluate the spec on its own terms — is it complete for the scope it chose? Do not expand scope. A spec that covers one area well is ready; one that is shallow is not.

Decision:
- If the spec is complete and meets all requirements: output the single word COMPLETED as the very last line of your response.
- If the spec needs more work: provide your research findings and concrete feedback. Do NOT output COMPLETED.

Do NOT modify any files. Do NOT move the spec file. You are read-only.
REVIEWER_EOF

  local MAX_ROUNDS=$max_rounds
  local ROUND=1
  local SPECCER_OUTPUT=""
  local SPEC_PATH=""

  echo "Starting autonomous spec for: \"${rough_idea}\""
  echo "Spec file prefix: ${SPEC_PATH_PREFIX}-<name>.md"
  echo ""

  # Round 1: Initial spec creation
  echo "━━━ Round ${ROUND}/${MAX_ROUNDS}: Creating initial spec ━━━"
  local claude_exit=0
  SPECCER_OUTPUT=$(claude --print --model "$model" \
    --allowedTools "Read Edit Write Bash Glob Grep WebSearch" \
    --disallowedTools "Bash(git push *)" \
    --append-system-prompt "${AUTO_SPECCER_PROMPT}" \
    "Rough feature idea: ${rough_idea}

Research the codebase and create the spec file at: ${SPEC_PATH_PREFIX}-<short-descriptive-name>.md") || claude_exit=$?

  if [[ $claude_exit -eq 130 || $claude_exit -eq 137 ]]; then
    echo ""
    echo "━━━ Auto spec cancelled by user. Spec remains in draft (if created). ━━━"
    exit 130
  fi

  echo "$SPECCER_OUTPUT"
  echo ""

  while [[ $ROUND -lt $MAX_ROUNDS ]]; do
    ROUND=$((ROUND + 1))

    # Discover spec file via glob
    SPEC_PATH="$(find_spec_by_prefix "$SPEC_PATH_PREFIX")"

    # Review phase
    echo "━━━ Round ${ROUND}/${MAX_ROUNDS}: Reviewing ━━━"
    local reviewer_exit=0
    local REVIEWER_OUTPUT
    local spec_context
    if [[ -n "$SPEC_PATH" ]]; then
      spec_context="Spec file path: ${SPEC_PATH}"
    else
      spec_context="No spec file found yet at prefix: ${SPEC_PATH_PREFIX}-*.md"
    fi

    REVIEWER_OUTPUT=$(claude --print --model "$model" \
      --allowedTools "Read Glob Grep WebSearch" \
      --append-system-prompt "${AUTO_REVIEWER_PROMPT}" \
      "Speccer output this round:
${SPECCER_OUTPUT}

${spec_context}

Review the spec and provide feedback, or output COMPLETED if the spec is ready.") || reviewer_exit=$?

    if [[ $reviewer_exit -eq 130 || $reviewer_exit -eq 137 ]]; then
      echo ""
      echo "━━━ Auto spec cancelled by user. Spec remains in draft (if created). ━━━"
      exit 130
    fi

    echo "$REVIEWER_OUTPUT"
    echo ""

    # Check for COMPLETED
    local LAST_LINE
    LAST_LINE=$(echo "$REVIEWER_OUTPUT" | sed '/^[[:space:]]*$/d' | tail -1)
    if [[ "$LAST_LINE" == "COMPLETED" ]]; then
      # Rediscover spec path in case it was just created
      SPEC_PATH="$(find_spec_by_prefix "$SPEC_PATH_PREFIX")"
      if [[ -n "$SPEC_PATH" ]]; then
        local spec_basename
        spec_basename="$(basename "$SPEC_PATH")"
        mv "$SPEC_PATH" "${SPEC_DIR}/ready/${spec_basename}"
        echo "━━━ Spec complete after ${ROUND} round(s) ━━━"
        echo "Moved ${spec_basename} → ready/"
      else
        echo "━━━ Spec complete after ${ROUND} round(s) ━━━"
        echo "Warning: could not find spec file to move to ready/."
      fi
      exit 0
    fi

    # Check if we've hit max rounds before refining
    if [[ $ROUND -ge $MAX_ROUNDS ]]; then
      break
    fi

    # Refine phase (same round — reviewer gave feedback, speccer incorporates it)
    echo "━━━ Round ${ROUND}/${MAX_ROUNDS}: Refining spec ━━━"
    local refine_exit=0
    # Rediscover spec path
    SPEC_PATH="$(find_spec_by_prefix "$SPEC_PATH_PREFIX")"
    local spec_path_msg
    if [[ -n "$SPEC_PATH" ]]; then
      spec_path_msg="Current spec file: ${SPEC_PATH}"
    else
      spec_path_msg="No spec file found yet. Create it at: ${SPEC_PATH_PREFIX}-<short-descriptive-name>.md"
    fi

    SPECCER_OUTPUT=$(claude --print --model "$model" \
      --allowedTools "Read Edit Write Bash Glob Grep WebSearch" \
      --disallowedTools "Bash(git push *)" \
      --append-system-prompt "${AUTO_SPECCER_PROMPT}" \
      "${spec_path_msg}

Reviewer feedback:
${REVIEWER_OUTPUT}

Read the current spec file (if it exists), incorporate the feedback above, and update the spec.") || refine_exit=$?

    if [[ $refine_exit -eq 130 || $refine_exit -eq 137 ]]; then
      echo ""
      echo "━━━ Auto spec cancelled by user. Spec remains in draft (if created). ━━━"
      exit 130
    fi

    echo "$SPECCER_OUTPUT"
    echo ""
  done

  echo "━━━ Hit max rounds (${MAX_ROUNDS}). Spec remains in draft/. ━━━"
  exit 1
}

specr_sync() {
  require_cmd claude

  ensure_state_dirs

  local dry_run=false
  if [[ ${1:-} == "--dry-run" ]]; then
    dry_run=true
  fi

  IFS= read -r -d '' SYNC_PROMPT <<'SYNC_EOF' || true
You are a spec state auditor. Your job is to analyze spec files and determine whether each one is in the correct state folder based on the actual codebase.

Instructions:

1. Discover all .md spec files across these folders under .specr/: draft/, ready/, in-progress/, completed/, and the .specr/ root (legacy orphans).
2. For each spec file found:
   a. Read the spec content, especially the task list (lines matching `- [ ]` and `- [x]`).
   b. Explore the codebase to verify whether the described changes actually exist — check for the files, functions, configs, or behaviors the spec describes.
   c. Determine the correct state:
      - draft — spec is incomplete, missing sections, or not yet actionable.
      - ready — spec is complete and well-formed, but no implementation work has started in the codebase.
      - in-progress — some but not all described work exists in the codebase.
      - completed — all described work is fully implemented in the codebase.
3. For each spec, report: current folder, recommended folder, and a one-line reason.
4. Move files that need to change (using mv) to their correct state folder — unless the user prompt indicates this is a dry run, in which case only report what would change without moving anything.

Output format — use a simple list, one spec per entry. Do NOT use tables. Example:

- spec-name.md: ready → completed (all tasks implemented)
- other-spec.md: draft (no change)

If any files were moved, end with a short "Moved N spec(s)" summary line.
SYNC_EOF

  local user_prompt
  if [[ "$dry_run" == true ]]; then
    user_prompt="Sync the spec files in .specr/ to their correct state folders. This is a dry run — report recommendations only, do NOT move any files."
    echo "Running sync (dry run)..."
  else
    user_prompt="Sync the spec files in .specr/ to their correct state folders. Move any files that are in the wrong state folder."
    echo "Running sync..."
  fi
  echo ""

  claude --print --model sonnet \
    --allowedTools "Read Edit Write Bash Glob Grep WebSearch" \
    --disallowedTools "Bash(git push *)" \
    --append-system-prompt "${SYNC_PROMPT}" \
    "${user_prompt}"
}

specr_create() {
  local use_claude=false
  if [[ ${1:-} == "--claude" ]]; then
    use_claude=true
    shift
  fi

  local spec_tool="codex"
  if [[ "$use_claude" == true ]]; then
    spec_tool="claude"
  fi

  require_cmd "$spec_tool"

  local ROUGH_IDEA="$*"
  local STAMP
  STAMP="$(date +%Y%m%d-%H%M%S)"
  local SPEC_PATH_PREFIX="${SPEC_DIR}/draft/spec-${STAMP}"

  ensure_state_dirs

  IFS= read -r -d '' SYSTEM_PROMPT <<'CREATE_EOF' || true
You are operating in a specialized workflow called Specr mode.

In Specr mode, your role is specification only. Your job is to help the user turn a rough feature idea into an implementable specification for this project. The goal is to make the speccing process feel simple, clear, collaborative, and lightweight.

Keep the energy up — be direct, friendly, and concise. Speccing can drag, so keep things moving. Say what you need to say without padding.

Use two distinct writing modes:
- Chat with the user: friendly and energetic.
- Spec document: concise, professional, neutral, and structured.

Do not let the chat sound like a design document, and do not let the spec sound like chat.

Your responsibilities and constraints in this mode:
- Help the user create and refine a specification.
- Do not implement the feature.
- In general, do not edit application code, tests, configs, migrations, or any project files other than the spec output file for this session. If you are explicitly instructed by the user to make an exception to this rule, thats fine.
- Do not switch into planning or execution mode.

Spec state folders

Specs live in state folders under __SPEC_DIR__/:

  draft/        — spec is being written or refined (initial state)
  ready/        — spec is finalized and ready for implementation
  in-progress/  — spec is currently being implemented
  completed/    — implementation is done

The normal flow is draft → ready → in-progress → completed, but states can be skipped when appropriate.

You are responsible for moving spec files between state folders during the session. To move a spec, use a shell command (e.g. mv) to relocate it from one folder to another, keeping the filename unchanged.

The spec output file for this session must live under: __SPEC_DIR__/draft/
Use this timestamped filename prefix for the session: __SPEC_PATH_PREFIX__
Once you understand the feature well enough to name it clearly, create the spec file exactly once using this format:

__SPEC_PATH_PREFIX__-<short-descriptive-name>.md

Keep the suffix short, specific, lowercase, and hyphenated.
After creating the file, use that same path for the rest of the session. Do not rename it later.

You were started from within the target project directory.

Workflow

Start by doing some lightweight research — read relevant code first and foremost, but also use web search or other tools if you need up-to-date docs or external context. The goal is to ask informed questions instead of wasting time on things you could have looked up.

Then have a real conversation with the user. This is the core of the process. The most important thing is making sure you truly understand what the user wants to achieve and why. Your research will give you a lot of context, but there will almost always be things that only the user can clarify. Have at least one round of discussion with the user to verify that you understand their intent correctly — getting this right is what makes the rest of the spec useful. Sometimes the user themselves may be uncertain or missing context; help them think it through and surface things they might not have considered. Once you are confident in the intent, dig into the details together: ask about constraints, preferences, and trade-offs. Challenge assumptions, explore the what ifs. Once conclusions start to solidify, go ahead and create the spec file using the exact format above.

As conclusions solidify, do deeper research in the codebase and consult external sources when useful to verify or disprove assumptions with high confidence. For example, read relevant package source code or use web search to confirm current API behavior mentioned in the spec.

Spec requirements

The spec must be implementable and include:
- What we are solving
- Technical implementation (this should be the largest section by far)
- Relevant findings about the current project
- Constraints and assumptions
- Acceptance criteria
- Task list with subtasks

The spec must be self-contained and written so that someone implementing it later can understand it without needing prior context from this conversation.

Task list requirements

The task list must:
- Use Markdown checklists in the form - [ ] so implementation progress can be tracked later.
- Be complete: if all tasks and subtasks are finished, the feature should be fully implemented.
- Be concrete and implementation-oriented, not just high-level themes.
- Reflect dependencies and ordering where that matters.
- Be optimized for agent-driven implementation: group related subtasks under meaningful top-level tasks, where each top-level task represents an independently committable unit of work. Avoid splitting into many tiny standalone tasks or collapsing everything into 1–2 massive tasks. There is no single right answer for task count — it depends entirely on the scope. A small feature might have 3 top-level tasks, a large one might have 20 or 30 or more. Those numbers are only examples, not targets. The only rule is that the list must be "ralph-able": correct, complete, and well-organized into logical top-level groups with clear subtasks. A large task list for a genuinely large feature is fine; an over-padded task list for a simple feature is not.

While developing the spec, consider how the feature affects end users, not just the technical implementation. When appropriate, think slightly beyond the most obvious implementation path and bring in useful product or UX considerations. If the work is primarily backend or infrastructure and broader user impact is not relevant, stay grounded in the technical context.

Be cautious about treating inferred details as final decisions. When something is uncertain, verify it through research or ask the user.

When useful, include sources for important conclusions. It is valuable both to confirm an assumption and to disprove one — and to report either outcome clearly.

Guiding the user toward ready

A spec in draft/ is not yet actionable. Your job is to help the user get it to ready/ — that is the finish line for this session.

Before a spec can move to ready, every open question must be resolved — either by researching yourself, or by asking the user. Do not leave ambiguities in the spec. If you can answer a question through research, do that instead of asking the user. Research means reading the codebase first and foremost, but also using web search or other tools when you need up-to-date docs, API behavior, or best practices. Only ask the user when the answer genuinely cannot be found through your own research.

As long as there are unresolved questions or gaps, keep asking. When all questions are resolved and the spec is complete — all sections filled out, task list solid, acceptance criteria clear — move the spec to ready/ yourself. Do not ask for permission to move it. Just move it, then tell the user:
- That the spec is ready.
- How to implement it: "Run `specr ralph` to start implementation — it picks up the latest ready spec automatically."
- Only for small specs (1 or 2 main tasks), mention they can also just run claude directly: `claude "implement the spec at <path>"`. If there are 3 or more main tasks, do NOT suggest one-shotting — default to recommending `specr ralph`.

Mention the current spec state (folder and file path) after creating it, after state changes, and when the user asks.
CREATE_EOF
  SYSTEM_PROMPT="${SYSTEM_PROMPT//__SPEC_DIR__/$SPEC_DIR}"
  SYSTEM_PROMPT="${SYSTEM_PROMPT//__SPEC_PATH_PREFIX__/$SPEC_PATH_PREFIX}"
  USER_PROMPT="Rough feature idea:
${ROUGH_IDEA}

Start Specr mode now."

  echo "Starting Specr in $(pwd) (using ${spec_tool})"
  echo "Spec file prefix: ${SPEC_PATH_PREFIX}-<short-descriptive-name>.md"

  if [[ "$use_claude" == true ]]; then
    exec claude --append-system-prompt "${SYSTEM_PROMPT}" "${USER_PROMPT}"
  else
    exec codex -c "developer_instructions=$(printf '%s' "${SYSTEM_PROMPT}")" --search "${USER_PROMPT}"
  fi
}

specr_update() {
  if [[ ! -d "$INSTALL_DIR/.git" ]]; then
    echo "Error: specr install directory not found at ${INSTALL_DIR}" >&2
    echo "If you installed specr elsewhere, cd there and run: git pull" >&2
    exit 1
  fi
  echo "Updating specr..."
  git -C "$INSTALL_DIR" pull --ff-only
  echo "Updated to $(git -C "$INSTALL_DIR" log -1 --format='%h %s')"
}

# Argument routing
if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "$1" in
  auto)
    shift
    specr_auto "$@"
    ;;
  list)
    specr_list
    ;;
  preflight)
    shift
    specr_preflight "$@"
    ;;
  sync)
    shift
    specr_sync "$@"
    ;;
  ralph)
    shift
    specr_ralph "$@"
    ;;
  update)
    specr_update
    ;;
  -v|--version)
    echo "specr ${VERSION}"
    exit 0
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  --claude)
    specr_create "$@"
    ;;
  *)
    specr_create "$@"
    ;;
esac
